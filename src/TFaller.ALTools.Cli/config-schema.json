{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "projectPath": {
            "type": "string",
            "description": "Location of the project folder. Can be ommited if the config file is in the project folder."
        },
        "transformations": {
            "type": "object",
            "additionalProperties": {
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "type:": {
                            "type": "string",
                            "enum": [
                                "comment-transform-var"
                            ]
                        },
                        "tags": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}